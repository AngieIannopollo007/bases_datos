-- Cree una función para cada punto teniendo en cuenta que
-- 1) El subsidio de transporte equivale al 7% al salario básico
    DELIMITER // 
    CREATE FUNCTION subsidio(
        CodEmp1 float
    )
    RETURNS float
    DETERMINISTIC
    BEGIN 
        DECLARE SAL float;
        DECLARE subsidio float;
        SELECT salario INTO sal FROM empleado WHERE CodEmp = CodEmp1;
        SET subsidio = sal * 0.07;
        RETURN subsidio;
    END;
