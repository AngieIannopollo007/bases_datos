-- 2) La salud que corresponde al 4% al salario básico
DELIMITER //
CREATE FUNCTION salud(
    CodEmp1 INT
)
RETURNS float
DETERMINISTIC
BEGIN 
    DECLARE salud FLOAT;
    DECLARE sal FLOAT;
    SELECT salario INTO sal FROM empleado WHERE CodEmp = CodEmp1;
    SET salud = sal * 0.04;
    RETURN salud;
END;//
